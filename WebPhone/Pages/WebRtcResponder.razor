@page "/webrtc/respond"
@using System.Text.Json
@using Microsoft.AspNetCore.Components
@implements IAsyncDisposable
@inject WebRtcService WebRtc
@inject IJSRuntime JsRuntime

<PageTitle>WebRTC Responder</PageTitle>

<div class="webrtc-page">
    <header class="webrtc-header">
        <h1>WebRTC Responder</h1>
        <p>Copy the confirmation line back to the initiator to finish the connection.</p>
    </header>

    <section class="webrtc-card">
        <h2>Confirmation line</h2>
        <div class="webrtc-field">
            <input class="webrtc-input" value="@confirmationPayload" readonly />
            <button class="webrtc-button" @onclick="CopyConfirmationAsync" disabled="@(string.IsNullOrWhiteSpace(confirmationPayload))">Copy</button>
        </div>
        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <p>@statusMessage</p>
        }
    </section>

    <section class="webrtc-card webrtc-status">
        <h2>Connection State</h2>
        <div>
            <span>Peer: @connectionState</span>
            <span>Data channel: @dataChannelState</span>
        </div>
    </section>

    <section class="webrtc-card">
        <h2>Audio</h2>
        <audio class="webrtc-audio" @ref="remoteAudio" autoplay controls></audio>
        @if (!string.IsNullOrWhiteSpace(audioStatusMessage))
        {
            <p>@audioStatusMessage</p>
        }
    </section>

    <section class="webrtc-card">
        <h2>Send a Message</h2>
        <div class="webrtc-field">
            <input class="webrtc-input" @bind="messageToSend" placeholder="Type a message" />
            <button class="webrtc-button" @onclick="SendMessageAsync" disabled="@(!CanSend)">Send</button>
        </div>

        <ul class="webrtc-messages">
            @foreach (var message in receivedMessages)
            {
                <li>@message</li>
            }
        </ul>
    </section>
</div>

@code {
    private readonly JsonSerializerOptions jsonOptions = new() { WriteIndented = true };
    private readonly List<string> receivedMessages = [];
    private string connectionId = "demo";
    private string? confirmationPayload;
    private string? statusMessage;
    private string? connectionState = "new";
    private string? dataChannelState = "new";
    private string messageToSend = string.Empty;
    private bool isInitialized;
    private string? processedOffer;
    private bool isAudioStarted;
    private ElementReference remoteAudio;
    private string? audioStatusMessage;

    [Parameter, SupplyParameterFromQuery(Name = "offer")]
    public string? EncodedOffer { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "id")]
    public string? ConnectionIdFromQuery { get; set; }

    private bool CanSend => dataChannelState == "open";

    protected override void OnInitialized()
    {
        WebRtc.ConnectionStateChanged += HandleConnectionStateChanged;
        WebRtc.DataChannelStateChanged += HandleDataChannelStateChanged;
        WebRtc.DataMessageReceived += HandleDataMessageReceived;
        WebRtc.RemoteStreamAvailable += HandleRemoteStreamAvailable;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(EncodedOffer))
        {
            statusMessage = "Missing offer in the link.";
            return;
        }

        if (processedOffer == EncodedOffer)
        {
            return;
        }

        processedOffer = EncodedOffer;
        connectionId = string.IsNullOrWhiteSpace(ConnectionIdFromQuery) ? "demo" : ConnectionIdFromQuery;
        statusMessage = null;

        var offer = DeserializeDescriptionFromPayload(EncodedOffer);
        if (offer is null)
        {
            statusMessage = "Offer payload is invalid.";
            return;
        }

        await EnsureInitializedAsync();
        await EnsureAudioAsync();
        await WebRtc.SetRemoteDescriptionAsync(connectionId, offer);
        var answer = await WebRtc.CreateAnswerAsync(connectionId);
        var json = JsonSerializer.Serialize(answer, jsonOptions);
        confirmationPayload = Base64UrlEncode(json);
        await InvokeAsync(StateHasChanged);
    }

    private async Task EnsureInitializedAsync()
    {
        if (isInitialized)
        {
            return;
        }

        await WebRtc.InitializeAsync(connectionId, [
            new WebRtcIceServer { Urls = ["stun:stun.l.google.com:19302"] }
        ]);
        isInitialized = true;
    }

    private async Task SendMessageAsync()
    {
        if (string.IsNullOrWhiteSpace(messageToSend))
        {
            return;
        }

        await WebRtc.SendMessageAsync(connectionId, messageToSend);
        receivedMessages.Add($"Me: {messageToSend}");
        messageToSend = string.Empty;
        await InvokeAsync(StateHasChanged);
    }

    private void HandleConnectionStateChanged(object? sender, WebRtcConnectionStateChangedEventArgs args)
    {
        if (args.ConnectionId != connectionId)
        {
            return;
        }

        connectionState = args.State;
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleDataChannelStateChanged(object? sender, WebRtcDataChannelStateChangedEventArgs args)
    {
        if (args.ConnectionId != connectionId)
        {
            return;
        }

        dataChannelState = args.State;
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleDataMessageReceived(object? sender, WebRtcDataMessageEventArgs args)
    {
        if (args.ConnectionId != connectionId)
        {
            return;
        }

        receivedMessages.Add($"Remote: {args.Message}");
        _ = InvokeAsync(StateHasChanged);
    }

    private async void HandleRemoteStreamAvailable(object? sender, WebRtcRemoteStreamEventArgs args)
    {
        if (args.ConnectionId != connectionId)
        {
            return;
        }

        await WebRtc.AttachRemoteAudioAsync(connectionId, remoteAudio);
    }

    private async Task EnsureAudioAsync()
    {
        if (isAudioStarted)
        {
            return;
        }

        try
        {
            await WebRtc.StartLocalStreamAsync(connectionId, new
            {
                audio = new
                {
                    echoCancellation = true,
                    noiseSuppression = true,
                    autoGainControl = true
                },
                video = false
            });
            await WebRtc.AddLocalTracksAsync(connectionId);
            isAudioStarted = true;
            audioStatusMessage = null;
        }
        catch (JSException ex)
        {
            audioStatusMessage = ex.Message;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static WebRtcSessionDescription? DeserializeDescriptionFromPayload(string payload)
    {
        var decodedJson = Base64UrlDecode(payload);
        return JsonSerializer.Deserialize<WebRtcSessionDescription>(decodedJson);
    }

    private static string Base64UrlEncode(string value)
    {
        var bytes = System.Text.Encoding.UTF8.GetBytes(value);
        return Convert.ToBase64String(bytes)
            .Replace('+', '-')
            .Replace('/', '_')
            .TrimEnd('=');
    }

    private static string Base64UrlDecode(string value)
    {
        var padded = value.Replace('-', '+').Replace('_', '/');
        var padding = 4 - (padded.Length % 4);
        if (padding is > 0 and < 4)
        {
            padded = padded.PadRight(padded.Length + padding, '=');
        }

        var bytes = Convert.FromBase64String(padded);
        return System.Text.Encoding.UTF8.GetString(bytes);
    }

    private async Task CopyConfirmationAsync()
    {
        if (string.IsNullOrWhiteSpace(confirmationPayload))
        {
            return;
        }

        _ = await JsRuntime.InvokeAsync<bool>("webrtcInterop.copyToClipboard", confirmationPayload);
    }

    public async ValueTask DisposeAsync()
    {
        WebRtc.ConnectionStateChanged -= HandleConnectionStateChanged;
        WebRtc.DataChannelStateChanged -= HandleDataChannelStateChanged;
        WebRtc.DataMessageReceived -= HandleDataMessageReceived;
        WebRtc.RemoteStreamAvailable -= HandleRemoteStreamAvailable;

        if (isInitialized)
        {
            await WebRtc.CloseAsync(connectionId);
        }
    }
}
