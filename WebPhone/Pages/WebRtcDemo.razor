@page "/webrtc"
@implements IAsyncDisposable
@inject WebPhone.Services.PhoneService Phone

<PageTitle>WebRTC Demo</PageTitle>

<div class="webrtc-page">
   @*  <header class="webrtc-header">
        <h1>WebRTC Demo</h1>
        <p>Enter your name to announce your presence. Select a user to connect.</p>
    </header> *@

    <div class="webrtc-shell">
        <main class="webrtc-main">
            <ProfileSettingsCard Phone="Phone" />
            <ActiveCallCard Phone="Phone" />
            <ContactCardsGrid Phone="Phone" />
        </main>
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        Phone.StateChanged += HandlePhoneStateChanged;
        await Phone.InitializeAsync();
    }

    private async void HandlePhoneStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        Phone.StateChanged -= HandlePhoneStateChanged;
        await Phone.DisposeAsync();
    }
}
